# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# API layer configuration
# VITE_API_BASE_URL: Optional base URL for backend requests, e.g. https://api.example.com
VITE_API_BASE_URL="http://47.76.239.170:8182"

# VITE_API_TIMEOUT: Request timeout in milliseconds
VITE_API_TIMEOUT="10000"

# VITE_API_USE_MOCK: Keep as true to use local mock handlers before real backend is ready
VITE_API_USE_MOCK="true"

# VITE_API_MOCK_DELAY: Mock response latency in milliseconds
VITE_API_MOCK_DELAY="250"

# VITE_API_TOKEN_KEY: LocalStorage key used to read the bearer token
VITE_API_TOKEN_KEY="access_token"

# ba-token / ba-user-token storage keys used by authenticated business APIs
VITE_API_BA_TOKEN_KEY="ba-token"
VITE_API_BA_USER_TOKEN_KEY="ba-user-token"

# App metadata used by the update-check UI
VITE_APP_VERSION="1.0.0"
VITE_APP_PLATFORM="android"
VITE_APP_CHANNEL="AppStore"
VITE_APP_BUILD_NUMBER="20260306.1"
